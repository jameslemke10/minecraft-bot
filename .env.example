# Minecraft server connection (matches server/docker-compose.yml defaults)
MC_HOST=localhost
MC_PORT=25565
MC_VERSION=1.20.4

# Which agents to spawn (comma-separated). Default if unset: atticus only.
# CLI overrides this: pnpm dev -- atticus brutus
# AGENTS=atticus,brutus

# Gemini — required. One key shared across all agents; metrics are per-agent.
# Get a key at https://aistudio.google.com/apikey (free tier covers dev usage).
GEMINI_API_KEY=

# Models per cognitive role. Latency is set by model choice, not throttling.
# Atticus / Brutus (Thalamus + PFC):
GEMINI_MODEL_FAST=gemini-2.5-flash-lite
GEMINI_MODEL_DELIBERATE=gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash-lite

# Dimitri experiment (curator + executive) — uses Gemini 3.x by default.
# See src/agents/dimitri/models.ts. Override here or leave unset for defaults.
# DIMITRI_MODEL_CURATOR=gemini-3.1-flash-lite
# DIMITRI_MODEL_EXECUTIVE=gemini-3.5-flash
# Heavier executive: DIMITRI_MODEL_EXECUTIVE=gemini-3.1-pro-preview

# Logging
LOG_LEVEL=info

# Browser-based viewer (free alternative to Minecraft client).
# Viewer ports are per-agent — see src/agents/<name>/index.ts.
VIEWER_ENABLED=true
