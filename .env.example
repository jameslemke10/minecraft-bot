# Minecraft server connection (matches server/docker-compose.yml defaults)
MC_HOST=localhost
MC_PORT=25565
MC_VERSION=1.20.4
MC_USERNAME=Atticus

# Gemini — required from M2 onward.
# Get a key at https://aistudio.google.com/apikey (free tier covers dev usage).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Logging
LOG_LEVEL=info

# Browser-based viewer (free alternative to Minecraft client).
# Two views run simultaneously — open both in tabs, Cmd+1/Cmd+2 to switch.
VIEWER_ENABLED=true
VIEWER_THIRD_PERSON_PORT=3000
VIEWER_FIRST_PERSON_PORT=3001
