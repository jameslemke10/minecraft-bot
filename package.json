{
  "name": "minecraft-bot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:atticus": "tsx watch src/main.ts -- atticus",
    "dev:brutus": "tsx watch src/main.ts -- brutus",
    "dev:both": "tsx watch src/main.ts -- atticus brutus",
    "dimitri": "tsx src/agents/dimitri/run.ts",
    "start": "tsx src/main.ts",
    "probe": "tsx src/tools/probe-percept.ts",
    "sense:check": "tsx src/tools/sense-check.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "server:up": "docker compose -f server/docker-compose.yml up -d",
    "server:down": "docker compose -f server/docker-compose.yml down",
    "server:logs": "docker compose -f server/docker-compose.yml logs -f",
    "server:reset": "docker compose -f server/docker-compose.yml down -v && rm -rf server/data && docker compose -f server/docker-compose.yml up -d"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "canvas": "^3.2.3",
    "dotenv": "^16.4.5",
    "mineflayer": "^4.23.0",
    "mineflayer-pathfinder": "^2.4.5",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "prismarine-block": "^1.23.0",
    "prismarine-viewer": "^1.30.0",
    "vec3": "^0.1.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas"
    ]
  }
}
